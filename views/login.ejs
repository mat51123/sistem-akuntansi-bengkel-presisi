<!DOCTYPE html>
<html class="light" lang="id">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Tailwind CSS via CDN with Forms plugin -->
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Google Material Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .login-bg {
            background: radial-gradient(circle at 10% 20%, rgb(0, 97, 148) 0%, rgb(4, 30, 48) 90.1%);
        }
    </style>
</head>
<body class="login-bg min-h-screen flex items-center justify-center p-4">
    <!-- Background glow spheres for visual premium depth -->
    <div class="absolute w-[300px] h-[300px] bg-sky-500/10 rounded-full blur-[100px] top-10 left-10 pointer-events-none"></div>
    <div class="absolute w-[400px] h-[400px] bg-blue-600/10 rounded-full blur-[120px] bottom-10 right-10 pointer-events-none"></div>

    <div class="w-full max-w-md bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-2xl shadow-2xl relative z-10">
        <!-- Logo and header -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center p-4 bg-sky-400/20 border border-sky-400/30 rounded-2xl text-sky-300 mb-4 shadow-inner">
                <span class="material-symbols-outlined text-[40px]" style="font-variation-settings: 'FILL' 1;">build_circle</span>
            </div>
            <h2 class="text-[24px] font-extrabold text-white tracking-tight">BENGKEL MAMAT RECING</h2>
            <p class="text-[12px] text-sky-200/70 mt-1.5 uppercase tracking-widest font-semibold">Sistem Akuntansi Keuangan</p>
        </div>

        <!-- Error Alert Banner -->
        <% if (error) { %>
            <div class="mb-6 p-4 bg-red-500/20 border border-red-500/40 text-red-200 rounded-lg text-[13px] flex items-center gap-2 animate-pulse">
                <span class="material-symbols-outlined text-[18px]">error</span>
                <span class="font-medium"><%= error %></span>
            </div>
        <% } %>

        <!-- Login Form -->
        <form action="/login" method="POST" class="space-y-5">
            <div>
                <label for="username" class="block text-[11px] font-bold text-sky-100/80 uppercase tracking-wider mb-2">Username</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-sky-300/60 text-[20px] pointer-events-none">account_circle</span>
                    <input type="text" name="username" id="username" required placeholder="admin" 
                        class="w-full rounded-xl bg-white/5 border border-white/15 pl-11 pr-4 py-3 text-[14px] text-white placeholder-sky-200/30 focus:bg-white/10 focus:border-sky-400 focus:ring-sky-400 transition-all">
                </div>
            </div>

            <div>
                <label for="password" class="block text-[11px] font-bold text-sky-100/80 uppercase tracking-wider mb-2">Password</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-sky-300/60 text-[20px] pointer-events-none">lock</span>
                    <input type="password" name="password" id="password" required placeholder="••••••••" 
                        class="w-full rounded-xl bg-white/5 border border-white/15 pl-11 pr-4 py-3 text-[14px] text-white placeholder-sky-200/30 focus:bg-white/10 focus:border-sky-400 focus:ring-sky-400 transition-all">
                </div>
            </div>

            <button type="submit" 
                class="w-full bg-gradient-to-r from-sky-500 to-blue-600 hover:from-sky-400 hover:to-blue-500 text-white font-bold text-[14px] py-3.5 px-4 rounded-xl shadow-lg shadow-sky-500/20 hover:shadow-sky-400/30 hover:scale-[1.01] active:scale-[0.99] transition-all flex items-center justify-center gap-2 mt-8">
                <span>Masuk ke Sistem</span>
                <span class="material-symbols-outlined text-[18px]">login</span>
            </button>
        </form>

        <div class="mt-8 pt-6 border-t border-white/10 text-center">
            <p class="text-[11px] text-sky-200/50">Gunakan akun default:<br><span class="font-semibold text-sky-300">username: admin</span> &amp; <span class="font-semibold text-sky-300">password: admin123</span></p>
        </div>
    </div>
</body>
</html>
