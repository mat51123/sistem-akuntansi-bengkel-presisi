<%- include('../partials/header') %>

<!-- Page Title Header -->
<div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
        <h3 class="text-[26px] font-bold text-slate-950 tracking-tight">Buku Jurnal Umum</h3>
        <p class="text-[14px] text-[#505f76] mt-1">Catatan kronologis ganda (Double-entry Ledger) yang merekam seluruh mutasi keuangan berdasarkan tanggal secara otomatis.</p>
    </div>
    
    <div class="flex gap-2">
        <button onclick="window.print()" class="bg-white border border-slate-300 text-slate-700 py-2.5 px-5 rounded-lg font-bold text-[13px] hover:bg-slate-50 transition-all flex items-center gap-1.5 shadow-sm">
            <span class="material-symbols-outlined text-[18px]">print</span>
            Cetak Jurnal (PDF)
        </button>
        <a href="/transaksi" class="bg-primary text-white py-2.5 px-5 rounded-lg font-bold text-[13px] hover:opacity-95 transition-all flex items-center gap-1.5 shadow-sm">
            <span class="material-symbols-outlined text-[14px]">add</span>
            Transaksi Baru
        </a>
    </div>
</div>

<!-- Form Filter Section Panel -->
<div class="bg-white rounded-lg border border-[#bfc7d2]/60 shadow-sm p-6 mb-8">
    <form action="/jurnal" method="GET" class="grid grid-cols-1 md:grid-cols-12 gap-6 items-end">
        <div class="md:col-span-3">
            <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wider mb-2">Tanggal Mulai</label>
            <input type="date" name="start_date" value="<%= filters.start_date || '' %>" class="w-full text-[13px] rounded-md border-slate-300 focus:border-primary focus:ring-primary">
        </div>

        <div class="md:col-span-3">
            <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wider mb-2">Tanggal Selesai</label>
            <input type="date" name="end_date" value="<%= filters.end_date || '' %>" class="w-full text-[13px] rounded-md border-slate-300 focus:border-primary focus:ring-primary">
        </div>

        <div class="md:col-span-4">
            <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wider mb-2">Saring Rekening Akun</label>
            <select name="kode_akun" class="w-full text-[13px] rounded-md border-slate-300 focus:border-primary focus:ring-primary bg-white">
                <option value="Semua" <%= !filters.kode_akun || filters.kode_akun === 'Semua' ? 'selected' : '' %>>-- Semua Rekening --</option>
                <% accounts.forEach((acc) => { %>
                    <option value="<%= acc.kode_akun %>" <%= filters.kode_akun === acc.kode_akun ? 'selected' : '' %>><%= acc.kode_akun %> - <%= acc.nama_akun %></option>
                <% }) %>
            </select>
        </div>

        <div class="md:col-span-2 flex gap-2">
            <a href="/jurnal" class="flex-1 text-center py-2.5 border border-slate-300 rounded text-slate-700 text-[13px] font-semibold hover:bg-slate-50 transition-colors">Reset</a>
            <button type="submit" class="flex-grow bg-primary text-white py-2.5 rounded text-[13px] font-bold hover:opacity-95 transition-all shadow-sm">Saring</button>
        </div>
    </form>
</div>

<!-- Ledger journal items card -->
<div class="bg-white rounded-lg border border-[#bfc7d2]/60 shadow-sm overflow-hidden">
    <table class="w-full text-left border-collapse" id="printLedger">
        <thead>
            <tr class="bg-slate-100/70 uppercase text-[11px] text-[#505f76] font-bold border-b border-[#bfc7d2]/30">
                <th class="px-6 py-4 w-32 text-center">Tanggal</th>
                <th class="px-6 py-4 w-28 text-center">Ref</th>
                <th class="px-6 py-4">Keterangan / Rekening Mutasi</th>
                <th class="px-6 py-4 w-44 text-right">Debit (Rp)</th>
                <th class="px-6 py-4 w-44 text-right">Kredit (Rp)</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100/60 text-[13px]">
            <% if (groupedJurnal.length === 0) { %>
                <tr>
                    <td colspan="5" class="px-6 py-16 text-center text-slate-500 italic">Tidak ditemukan entri jurnal yang cocok dengan filter pencarian Anda.</td>
                </tr>
            <% } else { %>
                <% groupedJurnal.forEach((tx) => { %>
                    <tr class="hover:bg-slate-50/20 transition-colors align-top">
                        <!-- Date -->
                        <td class="px-6 py-4 font-semibold font-mono-data text-slate-600 text-center border-r border-slate-50">
                            <%= tx.tanggal %>
                        </td>
                        
                        <!-- Reference details -->
                        <td class="px-6 py-4 font-bold font-mono-data text-primary text-center border-r border-slate-50">
                            JU-00<%= tx.id_transaksi %>
                        </td>

                        <!-- Ledger description rows -->
                        <td class="px-6 py-4 border-r border-slate-50">
                            <div class="space-y-1">
                                <% tx.items.forEach((item) => { %>
                                    <div class="py-1 <%= item.kredit > 0 ? 'pl-8 text-slate-500 italic' : 'font-bold text-slate-800' %>">
                                        <%= item.kode_akun %> - <%= item.nama_akun %>
                                    </div>
                                <% }) %>
                            </div>
                            <div class="mt-3 pt-2 border-t border-slate-100 text-[11px] text-[#505f76] tracking-wide uppercase font-medium">
                                Memo: <span class="text-slate-900 font-semibold normal-case"><%= tx.keterangan %></span>
                            </div>
                        </td>

                        <!-- Debit Values list -->
                        <td class="px-6 py-4 text-right font-mono-data border-r border-slate-50">
                            <div class="space-y-1">
                                <% tx.items.forEach((item) => { %>
                                    <div class="py-1 leading-none h-6 flex items-center justify-end">
                                        <%= item.debit > 0 ? 'Rp ' + item.debit.toLocaleString('id-ID') : '-' %>
                                    </div>
                                <% }) %>
                            </div>
                        </td>

                        <!-- Kredit Values list -->
                        <td class="px-6 py-4 text-right font-mono-data">
                            <div class="space-y-1">
                                <% tx.items.forEach((item) => { %>
                                    <div class="py-1 leading-none h-6 flex items-center justify-end">
                                        <%= item.kredit > 0 ? 'Rp ' + item.kredit.toLocaleString('id-ID') : '-' %>
                                    </div>
                                <% }) %>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            <% } %>
        </tbody>
        <tfoot>
            <tr class="bg-slate-100/50 font-black text-slate-900 border-t-2 border-slate-300 text-[14px]">
                <td colspan="3" class="px-6 py-5 text-right font-bold">TOTAL KESELURUHAN JURNAL</td>
                <td class="px-6 py-5 text-right font-mono-data text-primary border-r border-slate-100">
                    Rp <%= totalOverallDebit.toLocaleString('id-ID') %>
                </td>
                <td class="px-6 py-5 text-right font-mono-data text-primary">
                    Rp <%= totalOverallKredit.toLocaleString('id-ID') %>
                </td>
            </tr>
        </tfoot>
    </table>
</div>

<!-- Print overrides style to keep layout beautiful when printing to physical sheets -->
<style>
    @media print {
        aside, header, footer, form, button, a {
            display: none !important;
        }
        main {
            margin-left: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
        }
        body {
            background-color: #ffffff !important;
        }
        #printLedger {
            width: 100% !important;
            border: 1px solid #000000 !important;
        }
    }
</style>

<%- include('../partials/footer') %>
