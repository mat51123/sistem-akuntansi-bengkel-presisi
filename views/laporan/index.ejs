<%- include('../partials/header') %>

<!-- Page Title Header -->
<div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
        <h3 class="text-[26px] font-bold text-slate-950 tracking-tight">Laporan Keuangan Otomatis</h3>
        <p class="text-[14px] text-[#505f76] mt-1">Laporan finansial aktual yang disusun otomatis dari buku besar jurnal secara real-time.</p>
    </div>
    
    <button onclick="window.print()" class="bg-primary text-white py-2.5 px-5 rounded-lg font-bold text-[13px] hover:opacity-95 transition-all flex items-center gap-1.5 shadow-sm">
        <span class="material-symbols-outlined text-[18px]">print</span>
        Cetak Laporan Keuangan
    </button>
</div>

<!-- Tab Navigation links -->
<div class="flex gap-6 border-b border-slate-200 mb-8 px-1 print:hidden">
    <button onclick="switchReportTab('laba-rugi')" id="tabBtn_laba-rugi" class="pb-3 border-b-2 font-bold text-[14px] transition-all duration-150 text-primary border-primary">
        Laba Rugi
    </button>
    <button onclick="switchReportTab('perubahan-modal')" id="tabBtn_perubahan-modal" class="pb-3 border-b-2 font-semibold text-[14px] transition-all duration-150 text-slate-500 border-transparent hover:text-slate-800">
        Perubahan Modal
    </button>
    <button onclick="switchReportTab('neraca')" id="tabBtn_neraca" class="pb-3 border-b-2 font-semibold text-[14px] transition-all duration-150 text-slate-500 border-transparent hover:text-slate-800">
        Neraca (Balanced)
    </button>
</div>

<!-- Container for three interactive report sections -->
<div class="space-y-12">
    
    <!-- 1. LAPORAN LABA RUGI PANEL -->
    <div id="panel_laba-rugi" class="report-panel bg-white rounded-lg border border-[#bfc7d2]/60 shadow-sm p-8 max-w-3xl mx-auto">
        <div class="text-center mb-8 border-b border-slate-100 pb-6">
            <h4 class="font-extrabold text-[20px] text-slate-900 tracking-tight uppercase">BENGKEL MAMAT RECING</h4>
            <h5 class="font-bold text-[15px] text-slate-800 uppercase mt-1">Laporan Laba Rugi</h5>
            <p class="text-[12px] text-slate-500 mt-1">Untuk Periode Semester Mei 2026</p>
        </div>

        <!-- REVENUES BLOCK -->
        <div class="mb-6">
            <h6 class="text-[12px] font-black text-[#505f76] uppercase tracking-wider mb-2">PENDAPATAN</h6>
            <div class="divide-y divide-slate-100 pl-4">
                <% if (listPendapatan.length === 0) { %>
                    <div class="flex justify-between py-2 text-[13px] text-slate-500 italic">Belum ada akun pendapatan terpakai...</div>
                <% } else { %>
                    <% listPendapatan.forEach(item => { %>
                        <div class="flex justify-between py-2 text-[13px] font-medium text-slate-850">
                            <span><%= item.kode %> - <%= item.nama %></span>
                            <span class="font-mono-data">Rp <%= item.total.toLocaleString('id-ID') %></span>
                        </div>
                    <% }) %>
                <% } %>
            </div>
            <div class="flex justify-between py-3 border-t border-slate-300 border-dashed mt-2 pl-4 text-[13px] font-bold text-slate-900 bg-slate-50/50 px-3 rounded">
                <span>Total Pendapatan Bengkel</span>
                <span class="font-mono-data">Rp <%= totalPendapatan.toLocaleString('id-ID') %></span>
            </div>
        </div>

        <!-- EXPENSES BLOCK -->
        <div class="mb-8">
            <h6 class="text-[12px] font-black text-[#505f76] uppercase tracking-wider mb-2">BEBAN OPERASIONAL</h6>
            <div class="divide-y divide-slate-100 pl-4">
                <% if (listBeban.length === 0) { %>
                    <div class="flex justify-between py-2 text-[13px] text-slate-500 italic">Belum ada beban operasional terpakai...</div>
                <% } else { %>
                    <% listBeban.forEach(item => { %>
                        <div class="flex justify-between py-2 text-[13px] font-medium text-slate-850">
                            <span><%= item.kode %> - <%= item.nama %></span>
                            <span class="font-mono-data">Rp <%= item.total.toLocaleString('id-ID') %></span>
                        </div>
                    <% }) %>
                <% } %>
            </div>
            <div class="flex justify-between py-3 border-t border-slate-300 border-dashed mt-2 pl-4 text-[13px] font-bold text-slate-900 bg-slate-50/50 px-3 rounded">
                <span>Total Beban Operasional</span>
                <span class="font-mono-data">( Rp <%= totalBeban.toLocaleString('id-ID') %> )</span>
            </div>
        </div>

        <!-- NET INCOME SUMMARY -->
        <div class="bg-primary/10 border border-primary/20 p-5 rounded-lg flex justify-between items-center text-primary">
            <div>
                <span class="text-[15px] font-extrabold block">Laba Bersih Operasional</span>
                <span class="text-[11px] text-[#505f76] font-medium uppercase tracking-wider block mt-0.5">Pendapatan dikurangi Beban</span>
            </div>
            <span class="text-[20px] font-black font-mono-data decoration-double decoration-2 underline underline-offset-4">
                Rp <%= labaBersih.toLocaleString('id-ID') %>
            </span>
        </div>
    </div>


    <!-- 2. LAPORAN PERUBAHAN MODAL PANEL -->
    <div id="panel_perubahan-modal" class="report-panel bg-white rounded-lg border border-[#bfc7d2]/60 shadow-sm p-8 max-w-3xl mx-auto hidden">
        <div class="text-center mb-8 border-b border-slate-100 pb-6">
            <h4 class="font-extrabold text-[20px] text-slate-900 tracking-tight uppercase">BENGKEL MAMAT RECING</h4>
            <h5 class="font-bold text-[15px] text-slate-800 uppercase mt-1">Laporan Perubahan Modal</h5>
            <p class="text-[12px] text-slate-500 mt-1">Untuk Periode Semester Mei 2026</p>
        </div>

        <div class="space-y-4 px-2 text-[13px] font-medium">
            <div class="flex justify-between py-3 border-b border-slate-100">
                <span class="font-bold text-slate-800">1. Modal Pemilik (Awal Modal Mei)</span>
                <span class="font-mono-data">Rp <%= modalAwal.toLocaleString('id-ID') %></span>
            </div>
            
            <div class="flex justify-between py-3 border-b border-slate-100 text-emerald-800">
                <span class="font-medium flex items-center gap-1.5">(+) Saldo Laba Bersih</span>
                <span class="font-mono-data">Rp <%= labaBersih.toLocaleString('id-ID') %></span>
            </div>

            <div class="flex justify-between py-3 border-b border-slate-100 text-red-700">
                <span class="font-medium">(-) Saldo Pengambilan Pribadi (Prive)</span>
                <span class="font-mono-data">( Rp <%= totalPrive.toLocaleString('id-ID') %> )</span>
            </div>

            <div class="pt-6">
                <div class="bg-slate-50 border border-slate-200 p-5 rounded-lg flex justify-between items-center text-slate-900">
                    <div>
                        <span class="text-[15px] font-extrabold block">Modal Akhir Pemilik</span>
                        <span class="text-[11px] text-[#505f76] font-medium block mt-0.5">Akan dialokasikan ke Neraca</span>
                    </div>
                    <span class="text-[20px] font-mono-data font-black">
                        Rp <%= modalAkhir.toLocaleString('id-ID') %>
                    </span>
                </div>
            </div>
        </div>
    </div>


    <!-- 3. LAPORAN NERACA (BALANCED SHEET) PANEL -->
    <div id="panel_neraca" class="report-panel grid grid-cols-1 md:grid-cols-2 gap-8 hidden">
        <!-- LEFT COLUMN: ASSETS (KODE KEPALA 1) -->
        <div class="bg-white rounded-lg border border-[#bfc7d2]/60 shadow-sm p-8">
            <div class="border-b-2 border-primary/20 pb-3 mb-6">
                <h4 class="font-black text-[15px] text-primary uppercase tracking-wider">ASET (AKTIVA)</h4>
            </div>

            <div class="space-y-3 pl-2 min-h-64">
                <% if (listAset.length === 0) { %>
                    <p class="text-[12px] text-slate-500 italic py-6">Belum ada akun aset terdaftar...</p>
                <% } else { %>
                    <% listAset.forEach(a => { %>
                        <div class="flex justify-between py-2 border-b border-slate-100 text-[13px] font-medium text-slate-800">
                            <span><%= a.kode %> - <%= a.nama %></span>
                            <span class="font-mono-data"><%= a.total < 0 ? '( Rp ' + Math.abs(a.total).toLocaleString('id-ID') + ' )' : 'Rp ' + a.total.toLocaleString('id-ID') %></span>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <div class="border-t-2 border-slate-900 pt-4 mt-8 flex justify-between items-center text-[14px] font-black text-slate-900 bg-slate-50 p-4 rounded-md">
                <span>TOTAL AKTIVA / ASET</span>
                <span class="font-mono-data underline decoration-double decoration-2">Rp <%= totalAset.toLocaleString('id-ID') %></span>
            </div>
        </div>

        <!-- RIGHT COLUMN: LIABILITIES & EQUITY (KEWAJIBAN & EKUITAS) -->
        <div class="bg-white rounded-lg border border-[#bfc7d2]/60 shadow-sm p-8 flex flex-col justify-between">
            <div>
                <!-- LIABILITIES SECTION -->
                <div class="border-b-2 border-[#bfc7d2]/40 pb-3 mb-4">
                    <h4 class="font-black text-[15px] text-[#505f76] uppercase tracking-wider">KEWAJIBAN (PASIVA)</h4>
                </div>

                <div class="space-y-3 pl-2 mb-8">
                    <% if (listKewajiban.length === 0) { %>
                        <div class="flex justify-between py-2 text-[13px] text-slate-400 italic">Tidak ada saldo utang / kewajiban...</div>
                    <% } else { %>
                        <% listKewajiban.forEach(k => { %>
                            <div class="flex justify-between py-2 border-b border-slate-100 text-[13px] font-medium text-slate-850">
                                <span><%= k.kode %> - <%= k.nama %></span>
                                <span class="font-mono-data">Rp <%= k.total.toLocaleString('id-ID') %></span>
                            </div>
                        <% }) %>
                    <% } %>
                    <div class="flex justify-between py-2 font-bold text-[13px] text-slate-800">
                        <span>Total Kewajiban</span>
                        <span class="font-mono-data">Rp <%= totalKewajiban.toLocaleString('id-ID') %></span>
                    </div>
                </div>

                <!-- EQUITY SECTION WITH NEW MODAL AKHIR -->
                <div class="border-b-2 border-[#bfc7d2]/40 pb-3 mb-4">
                    <h4 class="font-black text-[15px] text-[#505f76] uppercase tracking-wider">EKUITAS (MODAL)</h4>
                </div>

                <div class="space-y-3 pl-2">
                    <div class="flex justify-between py-2 border-b border-slate-100 text-[13px] font-bold text-slate-850 bg-slate-50/50 px-2 rounded">
                        <span>Modal Akhir Pemilik (Dari Laporan Perubahan Modal)</span>
                        <span class="font-mono-data text-slate-900">Rp <%= modalAkhir.toLocaleString('id-ID') %></span>
                    </div>
                </div>
            </div>

            <!-- PASIVA GRAND TOTAL -->
            <div class="border-t-2 border-slate-900 pt-4 mt-8 flex justify-between items-center text-[14px] font-black text-slate-900 bg-slate-50 p-4 rounded-md">
                <span>TOTAL KEWAJIBAN &amp; EKUITAS</span>
                <span class="font-mono-data underline decoration-double decoration-2">Rp <%= totalKewajibanDanEkuitas.toLocaleString('id-ID') %></span>
            </div>
        </div>

        <!-- 4. MASSIVE PILL SHAPE BALANCE BADGE -->
        <div class="md:col-span-2 flex justify-center mt-6">
            <% if (Math.abs(totalAset - totalKewajibanDanEkuitas) < 0.01) { %>
                <div class="inline-flex items-center gap-4 bg-emerald-100 border border-emerald-300 px-10 py-5 rounded-full shadow-lg transition-transform duration-200">
                    <div class="bg-emerald-500 text-white rounded-full p-2 flex items-center justify-center">
                        <span class="material-symbols-outlined font-black" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-emerald-800 font-extrabold text-[12px] tracking-[0.2em] uppercase leading-none">Keuangan Seimbang (Balanced)</span>
                        <span class="text-emerald-950 font-black text-[22px] font-mono-data mt-1 leading-none">Rp <%= totalAset.toLocaleString('id-ID') %></span>
                    </div>
                </div>
            <% } else { %>
                <div class="inline-flex items-center gap-4 bg-red-100 border border-red-300 px-10 py-5 rounded-full shadow-lg transition-transform duration-200">
                    <div class="bg-red-500 text-white rounded-full p-2 flex items-center justify-center">
                        <span class="material-symbols-outlined font-black" style="font-variation-settings: 'FILL' 1;">error</span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-red-800 font-extrabold text-[12px] tracking-[0.2em] uppercase leading-none">Keuangan Tidak Seimbang (Unbalanced)</span>
                        <span class="text-red-950 font-black text-[22px] font-mono-data mt-1 leading-none">Selisih: Rp <%= Math.abs(totalAset - totalKewajibanDanEkuitas).toLocaleString('id-ID') %></span>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

</div>

<script>
    // Tab switching controller logic
    function switchReportTab(tabId) {
        // Toggle buttons active look
        const tabs = ['laba-rugi', 'perubahan-modal', 'neraca'];
        tabs.forEach(id => {
            const btn = document.getElementById(`tabBtn_${id}`);
            const panel = document.getElementById(`panel_${id}`);
            
            if (id === tabId) {
                // Active styles
                btn.className = "pb-3 border-b-2 font-bold text-[14px] transition-all duration-150 text-primary border-primary";
                panel.classList.remove('hidden');
                if(id === 'neraca') {
                    panel.classList.add('grid');
                } else {
                    panel.classList.add('block');
                }
            } else {
                // Inactive styles
                btn.className = "pb-3 border-b-2 font-semibold text-[14px] transition-all duration-150 text-slate-500 border-transparent hover:text-slate-800";
                panel.classList.add('hidden');
                panel.classList.remove('grid', 'block');
            }
        });
    }
</script>

<!-- CSS Print layout hacks to keep spreadsheet margins pristine and fit on physical A4 pages -->
<style>
    @media print {
        aside, header, footer, button, select, div.flex.border-b {
            display: none !important;
        }
        main {
            margin-left: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
        }
        .report-panel {
            display: block !important;
            margin: 0 auto 30px auto !important;
            border: 1px solid #ddd !important;
            box-shadow: none !important;
            page-break-inside: avoid !important;
        }
        #panel_neraca {
            display: grid !important;
            grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
            gap: 20px !important;
        }
    }
</style>

<%- include('../partials/footer') %>
